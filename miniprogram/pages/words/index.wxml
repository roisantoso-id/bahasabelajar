<view class="page words-page">
  <view class="safe-head"></view>
  <view class="eyebrow">KAMUS MINI</view><view class="title">我的词库</view>
  <view class="search"><text class="search-icon">⌕</text><input placeholder="搜索印尼语或中文" value="{{query}}" bindinput="onInput" confirm-type="search"/><text class="total">{{total}}</text></view>
  <scroll-view class="filters" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="filter-row">
      <view wx:for="{{filters}}" wx:key="value" class="filter {{(item.value === '' && !level && !status) || item.value === level || item.value === status ? 'active' : ''}}" data-value="{{item.value}}" bindtap="pickFilter">{{item.label}}</view>
    </view>
  </scroll-view>
  <view class="word-list">
    <view class="word-item {{expanded === item.id ? 'open' : ''}}" wx:for="{{items}}" wx:key="id" data-id="{{item.id}}" bindtap="toggle">
      <view class="word-line">
        <view class="letter">{{item.initial}}</view>
        <view class="word-info"><view><text class="word-name">{{item.word}}</text><text class="pos">{{item.pos}}</text></view><view class="meaning">{{item.meaning}}</view></view>
        <view class="status {{item.status || 'new'}}">{{item.status === 'mastered' ? '已掌握' : item.status === 'reviewing' ? 'S' + item.stage : '新词'}}</view>
      </view>
      <view wx:if="{{expanded === item.id}}" class="examples">
        <view wx:for="{{item.examples}}" wx:key="id" wx:for-item="example"><view class="sentence">{{example.id}}</view><view class="translation">{{example.zh}}</view></view>
      </view>
    </view>
    <view wx:if="{{loading}}" class="list-tip">正在翻词典…</view><view wx:elif="{{!items.length}}" class="empty">没有找到这个词</view>
  </view>
</view>
