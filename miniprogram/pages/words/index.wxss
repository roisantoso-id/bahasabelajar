.words-page { padding-left: 0; padding-right: 0; }.words-page > .eyebrow, .words-page > .title { margin-left: 32rpx; }.title { margin-bottom: 30rpx; }
.search { height: 92rpx; display: flex; align-items: center; margin: 0 32rpx; padding: 0 24rpx; border-radius: 27rpx; background: #fffdf8; box-shadow: 0 9rpx 30rpx rgba(25,55,46,.06); }.search-icon { margin-right: 16rpx; color: #537066; font-size: 38rpx; }.search input { flex: 1; font-size: 26rpx; }.total { min-width: 54rpx; padding: 7rpx 12rpx; text-align: center; border-radius: 99rpx; color: #63726b; background: #edf1eb; font-size: 19rpx; font-weight: 700; }
.filters { width: 100%; margin: 24rpx 0 28rpx; }.filter-row { display: flex; gap: 14rpx; padding: 0 32rpx; white-space: nowrap; }.filter { flex: none; padding: 15rpx 25rpx; border: 1rpx solid #dedfd9; border-radius: 99rpx; color: #707a74; background: rgba(255,255,255,.45); font-size: 22rpx; font-weight: 650; }.filter.active { border-color: #174d40; color: #fff; background: #174d40; }
.word-list { margin: 0 24rpx; overflow: hidden; border-radius: 32rpx; background: #fffdf8; box-shadow: 0 10rpx 36rpx rgba(25,55,46,.06); }.word-item { padding: 26rpx 22rpx; border-bottom: 1rpx solid #eceae3; }.word-item:last-child { border-bottom: 0; }.word-item.open { background: #f8f7f1; }.word-line { display: flex; align-items: center; }.letter { width: 66rpx; height: 66rpx; display: flex; align-items: center; justify-content: center; flex: none; border-radius: 21rpx; color: #174d40; background: #dcebdc; font-family: Georgia, serif; font-size: 29rpx; font-weight: 800; }.word-info { flex: 1; min-width: 0; margin-left: 20rpx; }.word-name { font-family: Georgia, serif; font-size: 31rpx; font-weight: 800; }.pos { margin-left: 12rpx; color: #a0a59f; font-size: 20rpx; font-style: italic; }.meaning { max-width: 430rpx; margin-top: 8rpx; overflow: hidden; color: #747e77; font-size: 23rpx; text-overflow: ellipsis; white-space: nowrap; }.status { flex: none; padding: 8rpx 14rpx; border-radius: 99rpx; color: #8b918d; background: #f0eee8; font-size: 18rpx; font-weight: 700; }.status.reviewing { color: #2d745f; background: #dcebdc; }.status.mastered { color: #a44a34; background: #fbe1d8; }
.examples { margin: 24rpx 0 0 86rpx; padding-top: 22rpx; border-top: 1rpx dashed #dcded8; }.examples > view { margin-bottom: 20rpx; }.sentence { font-size: 25rpx; line-height: 1.5; font-weight: 650; }.translation { margin-top: 6rpx; color: #858d87; font-size: 21rpx; }.list-tip { padding: 34rpx; text-align: center; color: #929791; font-size: 21rpx; }
