.home-page { overflow: hidden; }
.topline { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0 34rpx; }
.date { margin-top: 9rpx; font-size: 34rpx; font-weight: 800; }
.streak { display: flex; align-items: baseline; gap: 5rpx; min-width: 116rpx; padding: 14rpx 18rpx; border-radius: 24rpx; background: #fff; color: #68736d; font-size: 21rpx; box-shadow: 0 8rpx 28rpx rgba(25,55,46,.07); }
.flame { margin-right: 4rpx; color: #f17455; transform: rotate(45deg); }.streak-num { color: #16352e; font-size: 33rpx; font-weight: 800; }
.hero { position: relative; height: 366rpx; overflow: hidden; background: #dcebdc; box-shadow: none; }
.hero-copy { position: relative; z-index: 2; width: 58%; padding: 44rpx 0 0 36rpx; }.hero-kicker { color: #2d745f; font-size: 19rpx; font-weight: 800; letter-spacing: 3rpx; }
.hero-title { margin-top: 16rpx; font-size: 44rpx; line-height: 1.28; font-weight: 900; letter-spacing: -2rpx; }.hero-image { position: absolute; z-index: 1; right: -42rpx; bottom: -24rpx; width: 390rpx; height: 340rpx; }
.hero-progress { display: flex; align-items: center; gap: 14rpx; margin-top: 34rpx; color: #2d745f; font-size: 21rpx; font-weight: 800; }.progress-track { width: 184rpx; height: 11rpx; overflow: hidden; border-radius: 99rpx; background: rgba(23,77,64,.13); }.progress-fill { height: 100%; border-radius: inherit; background: #174d40; }
.section-head { display: flex; align-items: baseline; justify-content: space-between; margin: 40rpx 4rpx 22rpx; }.section-head .muted { font-size: 21rpx; }
.task { display: flex; align-items: center; min-height: 142rpx; margin-bottom: 18rpx; padding: 24rpx; border-radius: 30rpx; background: #fffdf8; box-shadow: 0 10rpx 32rpx rgba(25,55,46,.06); }
.task-icon { width: 86rpx; height: 86rpx; display: flex; align-items: center; justify-content: center; flex: none; border-radius: 26rpx; font-size: 29rpx; font-weight: 900; }.learn-task .task-icon { color: #174d40; background: #dcebdc; }.review-task .task-icon { color: #a44a34; background: #fbe1d8; font-size: 42rpx; }
.task-body { flex: 1; margin-left: 22rpx; }.task-name { font-size: 29rpx; font-weight: 800; }.task-desc { margin-top: 10rpx; color: #879089; font-size: 21rpx; }.task-count { color: #7c857f; font-size: 20rpx; }.count-num { color: #16352e; font-size: 37rpx; font-weight: 900; }.arrow { margin-left: 12rpx; color: #abb1ac; font-size: 45rpx; }
.grammar-task .task-icon { color: #6b4c9a; background: #ebe0f5; }
.mini-stats { display: flex; align-items: center; justify-content: space-around; margin-top: 26rpx; padding: 27rpx 8rpx; }.mini-stats > view:not(.divider) { min-width: 150rpx; display: flex; flex-direction: column; align-items: center; }.stat-value { font-size: 32rpx; font-weight: 900; }.stat-label { margin-top: 8rpx; color: #8a928c; font-size: 19rpx; }.divider { width: 1rpx; height: 52rpx; background: #e7e5dd; }
