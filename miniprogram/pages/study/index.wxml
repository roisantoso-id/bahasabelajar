<view class="study-page">
  <view class="safe-head"></view>
  <view class="study-head">
    <button class="close" bindtap="close">×</button>
    <view class="head-progress"><view class="head-progress-fill" style="width: {{progress}}%"></view></view>
    <text class="counter">{{completed}}/{{total}}</text>
  </view>

  <view wx:if="{{loading}}" class="state">正在准备今日单词…</view>
  <view wx:elif="{{empty}}" class="state">
    <view class="state-mark">✓</view><view class="state-title">今天已经完成啦</view>
    <view class="state-text">去喝杯水，让记忆安静地生长。</view>
    <button class="primary-button state-button" bindtap="backHome">返回首页</button>
  </view>
  <view wx:elif="{{done}}" class="state">
    <view class="state-mark coral">◆</view><view class="state-title">做得漂亮</view>
    <view class="state-text">完成 {{total}} 个单词，答错 {{wrongTotal}} 次。</view>
    <button class="primary-button state-button" bindtap="backHome">完成训练</button>
  </view>

  <block wx:else>
    <scroll-view class="word-card" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="word-meta">
        <text class="level">{{word.level === 1 ? '入门' : word.level === 2 ? '初级' : '中级'}}</text>
        <text class="sound">♪</text>
      </view>
      <view class="word-main">{{word.word}}</view>
      <view class="word-pos">{{word.pos}}</view>
      <view wx:if="{{!revealed}}" class="think-hint">
        <view class="hint-line"></view><text>先在脑海里回想它的意思</text><view class="hint-line"></view>
      </view>
      <view wx:else class="answer">
        <view class="meaning">{{word.meaning}}</view>
        <view class="example" wx:for="{{word.examples}}" wx:key="id">
          <view class="sentence">{{item.id}}</view><view class="translation">{{item.zh}}</view>
        </view>
      </view>
    </scroll-view>

    <view class="actions">
      <block wx:if="{{!revealed}}">
        <button class="unknown" bindtap="revealUnknown"><text class="btn-symbol">×</text><text>不认识</text></button>
        <button class="know" bindtap="revealKnown"><text class="btn-symbol">✓</text><text>认识</text></button>
      </block>
      <block wx:else>
        <button wx:if="{{word.wrongTimes}}" class="primary-button single" bindtap="nextAfterWrong">继续，下次我会记住</button>
        <block wx:else>
          <button class="easy" bindtap="chooseEasy">太简单了</button>
          <button class="know" bindtap="chooseKnown">记住了</button>
        </block>
      </block>
    </view>
  </block>
</view>
