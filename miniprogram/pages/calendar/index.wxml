<view class="page calendar-page">
  <view class="safe-head"></view><view class="eyebrow">KEBIASAAN BAIK</view><view class="title">学习日历</view>
  <view class="streak-card">
    <view><view class="streak-label">连续学习</view><view><text class="streak-number">{{streak}}</text><text class="streak-unit"> 天</text></view><view class="streak-copy">让小小的坚持，变成语言直觉。</view></view>
    <view class="streak-badge"><view class="diamond">◆</view><text>{{totalDays}} 次打卡</text></view>
  </view>
  <view class="calendar card">
    <view class="month-head"><button data-delta="-1" bindtap="shiftMonth">‹</button><text>{{monthLabel}}</text><button data-delta="1" bindtap="shiftMonth">›</button></view>
    <view class="week"><text wx:for="{{weeks}}" wx:key="*this">{{item}}</text></view>
    <view class="grid">
      <view wx:for="{{cells}}" wx:key="key" class="day {{item.blank ? 'blank' : ''}} {{item.done ? 'done' : ''}} {{item.active ? 'active' : ''}} {{item.today ? 'today' : ''}}">
        <text wx:if="{{!item.blank}}">{{item.day}}</text><view wx:if="{{item.done}}" class="check">✓</view>
      </view>
    </view>
    <view class="legend"><view><view class="done-dot"></view>完成打卡</view><view><view class="active-dot"></view>有学习</view><view><view class="today-dot"></view>今天</view></view>
  </view>
  <view class="quote"><text>“ Sedikit demi sedikit, lama-lama menjadi bukit. ”</text><text>积少成多，终成高山。</text></view>
</view>
