.title { margin-bottom: 32rpx; }.streak-card { display: flex; align-items: center; justify-content: space-between; padding: 34rpx; border-radius: 34rpx; color: #fff; background: #174d40; box-shadow: 0 18rpx 36rpx rgba(23,77,64,.18); }.streak-label { color: rgba(255,255,255,.62); font-size: 21rpx; font-weight: 700; }.streak-number { font-size: 72rpx; line-height: 1.15; font-weight: 900; }.streak-unit { font-size: 25rpx; }.streak-copy { color: rgba(255,255,255,.58); font-size: 20rpx; }.streak-badge { width: 154rpx; height: 154rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: 50%; color: #174d40; background: #f4c95d; font-size: 19rpx; font-weight: 800; }.diamond { margin-bottom: 7rpx; color: #f17455; font-size: 42rpx; transform: rotate(45deg); }
.calendar { margin-top: 24rpx; padding: 28rpx 24rpx 24rpx; }.month-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 26rpx; font-size: 29rpx; font-weight: 900; }.month-head button { width: 62rpx; height: 62rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; color: #46655b; background: #edf3eb; font-size: 40rpx; }.week, .grid { display: grid; grid-template-columns: repeat(7, 1fr); }.week { margin-bottom: 10rpx; color: #9ba19c; font-size: 19rpx; text-align: center; }.day { position: relative; height: 76rpx; display: flex; align-items: center; justify-content: center; margin: 2rpx; border-radius: 22rpx; font-size: 23rpx; font-weight: 650; }.day.active { background: #f0f3ed; }.day.done { color: #fff; background: #2d745f; }.day.today { outline: 3rpx solid #f17455; outline-offset: -3rpx; }.check { position: absolute; right: 5rpx; bottom: 3rpx; font-size: 15rpx; }.legend { display: flex; justify-content: center; gap: 26rpx; margin-top: 24rpx; padding-top: 22rpx; border-top: 1rpx solid #eceae3; color: #8a918c; font-size: 18rpx; }.legend view { display: flex; align-items: center; gap: 7rpx; }.legend i { width: 14rpx; height: 14rpx; border-radius: 50%; }.done-dot { background: #2d745f; }.active-dot { background: #e3e9df; }.today-dot { border: 3rpx solid #f17455; }
.quote { display: flex; flex-direction: column; gap: 8rpx; margin: 28rpx 16rpx 0; text-align: center; color: #738078; font-family: Georgia, serif; font-size: 21rpx; font-style: italic; }.quote text:last-child { color: #a1a59f; font-family: sans-serif; font-size: 18rpx; font-style: normal; }
.legend > view > view { width: 14rpx; height: 14rpx; border-radius: 50%; }
