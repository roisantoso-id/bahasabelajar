.grammar-page { padding-bottom: calc(60rpx + env(safe-area-inset-bottom)); }
.grammar-head { display: flex; align-items: center; gap: 16rpx; margin-bottom: 8rpx; }
.back-btn { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: var(--paper); box-shadow: 0 4rpx 16rpx rgba(25,55,46,.08); font-size: 40rpx; color: var(--green); }
.grammar-title { font-size: 44rpx; font-weight: 800; letter-spacing: -1rpx; flex: 1; }
.lesson-tag { flex: none; padding: 8rpx 20rpx; border-radius: 99rpx; background: var(--mint); color: var(--green); font-size: 22rpx; font-weight: 700; }
.subtitle { margin-bottom: 32rpx; color: var(--muted); font-size: 24rpx; font-style: italic; }

.rule-card { margin-bottom: 24rpx; padding: 28rpx 28rpx 24rpx; border-radius: 28rpx; }
.rule-head { display: flex; align-items: center; justify-content: space-between; }
.rule-pattern { font-size: 32rpx; font-weight: 800; color: var(--green); font-family: Georgia, serif; }
.rule-arrow { color: var(--muted); font-size: 28rpx; }
.rule-meaning { margin-top: 10rpx; color: #555; font-size: 25rpx; line-height: 1.5; }

.rule-detail { margin-top: 24rpx; padding-top: 24rpx; border-top: 1rpx dashed #ddd; }
.rule-explain { color: #444; font-size: 25rpx; line-height: 1.7; margin-bottom: 24rpx; }

.rule-examples { }
.example-item { margin-bottom: 24rpx; padding: 20rpx; border-radius: 18rpx; background: #f7f5ef; }
.example-item:last-child { margin-bottom: 0; }
.ex-word { display: flex; align-items: baseline; gap: 12rpx; margin-bottom: 10rpx; }
.ex-id { font-size: 28rpx; font-weight: 800; color: var(--green); font-family: Georgia, serif; }
.ex-root { font-size: 21rpx; color: var(--muted); }
.ex-sentence { font-size: 26rpx; font-weight: 650; line-height: 1.6; }
.ex-zh { margin-top: 6rpx; font-size: 22rpx; color: #888; line-height: 1.5; }
