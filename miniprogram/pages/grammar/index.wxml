<view class="grammar-page page">
  <view class="safe-head"></view>
  <view class="grammar-head">
    <button class="back-btn" bindtap="close">‹</button>
    <text class="grammar-title">语法笔记</text>
    <text class="lesson-tag">第{{lesson}}课</text>
  </view>
  <view class="subtitle">Tata Bahasa · Pelajaran ke-{{lesson}}</view>

  <view wx:if="{{loading}}" class="empty">正在加载语法规则…</view>
  <view wx:elif="{{!rules.length}}" class="empty">暂无语法内容</view>

  <view wx:for="{{rules}}" wx:key="id" class="rule-card card {{expanded === index ? 'open' : ''}}" bindtap="toggle" data-idx="{{index}}">
    <view class="rule-head">
      <view class="rule-pattern">{{item.pattern}}</view>
      <view class="rule-arrow">{{expanded === index ? '▾' : '›'}}</view>
    </view>
    <view class="rule-meaning">{{item.meaning}}</view>

    <view wx:if="{{expanded === index}}" class="rule-detail">
      <view class="rule-explain">{{item.explain}}</view>
      <view class="rule-examples">
        <view class="example-item" wx:for="{{item.examples}}" wx:for-item="ex" wx:key="id">
          <view class="ex-word" wx:if="{{ex.root}}">
            <text class="ex-id">{{ex.id}}</text>
            <text class="ex-root">← {{ex.root}}</text>
          </view>
          <view class="ex-sentence">{{ex.sentence}}</view>
          <view class="ex-zh">{{ex.zh}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
