.title { margin-bottom: 32rpx; }.profile { display: flex; align-items: center; padding: 26rpx; }.avatar { width: 94rpx; height: 94rpx; display: flex; align-items: center; justify-content: center; border-radius: 30rpx; color: #fff; background: #174d40; font-family: Georgia, serif; font-size: 48rpx; font-weight: 800; }.profile-copy { flex: 1; margin-left: 22rpx; font-size: 29rpx; font-weight: 800; }.profile-copy text { display: block; margin-top: 9rpx; color: #8a918c; font-size: 20rpx; font-weight: 400; }.profile-mark { padding: 8rpx 14rpx; border-radius: 99rpx; color: #174d40; background: #f4c95d; font-size: 17rpx; font-weight: 900; }.group-title { margin: 36rpx 8rpx 16rpx; color: #69766f; font-size: 22rpx; font-weight: 800; }
.setting-card { padding: 0 26rpx; }.setting-row { min-height: 132rpx; display: flex; align-items: center; }.setting-icon { width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; flex: none; border-radius: 22rpx; font-size: 25rpx; font-weight: 900; }.setting-icon.green { color: #174d40; background: #dcebdc; }.setting-icon.coral { color: #a44a34; background: #fbe1d8; font-size: 34rpx; }.setting-copy { flex: 1; margin-left: 18rpx; font-size: 26rpx; font-weight: 750; }.setting-copy text { display: block; margin-top: 7rpx; color: #969c97; font-size: 19rpx; font-weight: 400; }.line { height: 1rpx; margin-left: 90rpx; background: #eceae3; }.stepper { height: 66rpx; display: flex; align-items: center; overflow: hidden; border: 1rpx solid #dfe1db; border-radius: 19rpx; }.stepper button { width: 58rpx; height: 100%; display: flex; align-items: center; justify-content: center; color: #2d6253; background: #f0f3ed; font-size: 30rpx; }.stepper text { min-width: 58rpx; text-align: center; font-size: 23rpx; font-weight: 800; }
.server { padding: 26rpx; }.server-head { display: flex; align-items: center; justify-content: space-between; font-size: 26rpx; font-weight: 800; }.server-head text { display: block; margin-top: 8rpx; color: #979d98; font-size: 19rpx; font-weight: 400; }.online { width: 18rpx; height: 18rpx; border-radius: 50%; background: #56a77c; box-shadow: 0 0 0 8rpx #e2f0e5; }.server input { height: 84rpx; margin-top: 24rpx; padding: 0 22rpx; border-radius: 20rpx; color: #34564c; background: #f1f3ee; font-family: monospace; font-size: 22rpx; }.notice { display: flex; gap: 16rpx; margin: 20rpx 10rpx 0; color: #8a918c; font-size: 19rpx; line-height: 1.55; }.notice > text { width: 32rpx; height: 32rpx; display: flex; align-items: center; justify-content: center; flex: none; border-radius: 50%; color: #fff; background: #98a19b; font-size: 18rpx; font-weight: 800; }.save { margin-top: 34rpx; }.version { margin-top: 30rpx; text-align: center; color: #adb1ad; font-size: 18rpx; }
