page {
  --ink: #16352e;
  --muted: #7c857f;
  --green: #174d40;
  --green-2: #2d745f;
  --mint: #dcebdc;
  --cream: #f4f1e9;
  --paper: #fffdf8;
  --coral: #f17455;
  --yellow: #f4c95d;
  background: var(--cream);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
  font-size: 28rpx;
}

view, text, image, button, input, picker { box-sizing: border-box; }
button::after { border: 0; }
button { margin: 0; padding: 0; line-height: 1; background: transparent; }

.page { min-height: 100vh; padding: 0 32rpx calc(148rpx + env(safe-area-inset-bottom)); }
.safe-head { height: calc(26rpx + env(safe-area-inset-top)); }
.eyebrow { font-size: 22rpx; font-weight: 700; letter-spacing: 3rpx; color: var(--green-2); }
.title { margin-top: 12rpx; font-size: 52rpx; line-height: 1.15; font-weight: 800; letter-spacing: -2rpx; }
.section-title { font-size: 30rpx; font-weight: 800; }
.card { background: var(--paper); border-radius: 32rpx; box-shadow: 0 12rpx 40rpx rgba(25, 55, 46, .07); }
.pill { display: inline-flex; align-items: center; min-height: 48rpx; padding: 0 20rpx; border-radius: 999rpx; font-size: 22rpx; font-weight: 700; }
.primary-button { display: flex; align-items: center; justify-content: center; height: 104rpx; border-radius: 28rpx; background: var(--green); color: #fff; font-size: 30rpx; font-weight: 800; box-shadow: 0 14rpx 28rpx rgba(23,77,64,.22); }
.ghost-button { display: flex; align-items: center; justify-content: center; height: 104rpx; border-radius: 28rpx; background: #fff; color: var(--green); font-size: 30rpx; font-weight: 800; }
.muted { color: var(--muted); }
.empty { padding: 100rpx 24rpx; text-align: center; color: var(--muted); }
